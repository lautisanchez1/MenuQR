# =============================================================================
# MenuQR Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=menuqr
POSTGRES_USER=menuqr
POSTGRES_PASSWORD=your_secure_password_here

# Backend database connection
# IMPORTANTE:
# - Con Docker Compose (recomendado): el archivo compose fija DB_URL a host "postgres".
#   No hace falta definir DB_URL aquí salvo que uses un compose personalizado.
# - Si ejecutás el backend en tu PC (mvn quarkus:dev, IDE) con Postgres en Docker:
#   usá localhost, porque "postgres" solo existe dentro de la red Docker.
#   DB_URL=jdbc:postgresql://127.0.0.1:5432/menuqr
DB_URL=jdbc:postgresql://postgres:5432/menuqr
DB_USER=menuqr
DB_PASS=your_secure_password_here

# =============================================================================
# AWS Configuration
# =============================================================================
# For local development, use 'local' credentials with DynamoDB Local
# For production, use real AWS credentials
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1

# =============================================================================
# DynamoDB (Analytics)
# =============================================================================
# Table name for storing analytics events
DYNAMO_TABLE=menuqr-events

# For local development with DynamoDB Local:
DYNAMO_ENDPOINT=http://dynamodb-local:8000
# For production, leave empty to use AWS DynamoDB:
# DYNAMO_ENDPOINT=

# =============================================================================
# S3 (Image Storage) - MinIO for local development
# =============================================================================
S3_BUCKET=menuqr-images

# For local development with MinIO (configured automatically in infrastructure/docker/docker-compose.yml):
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000

# For production with AWS S3, leave these empty:
# S3_ENDPOINT=
# S3_PUBLIC_URL=

# =============================================================================
# Frontend Configuration
# =============================================================================
# API URL that frontend apps will use to connect to backend
VITE_API_URL=http://localhost:8080

# Public URL of the customer-facing menu app.
# Used by the admin to generate QR codes that point to the correct menu URL.
# In production, set this to your menu domain (e.g. https://menu.yourdomain.com).
# In local dev, defaults to http://localhost:5173 if not set.
VITE_MENU_URL=http://localhost:5173

# =============================================================================
# Recommendation model (optional S3 artifact; inference still mock in app)
# En producción: bucket DEDICADO a modelos (no mezclar con imágenes del menú).
# =============================================================================
# RECOMMENDATIONS_MODEL_S3_BUCKET=menuqr-models-your-account
# RECOMMENDATIONS_MODEL_S3_KEY=recommendations/v1/model.onnx

# =============================================================================
# Application Profile
# =============================================================================
# Options: dev, test, prod
QUARKUS_PROFILE=dev

# =============================================================================
# JWT Keys (Optional - defaults exist for development)
# =============================================================================
# Path to JWT private key for signing tokens
# JWT_PRIVATE_KEY_PATH=privateKey.pem
# Path to JWT public key for verifying tokens
# JWT_PUBLIC_KEY_PATH=publicKey.pem
