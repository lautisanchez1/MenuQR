# =============================================================================
# MenuDigital Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=menudigital
POSTGRES_USER=menudigital
POSTGRES_PASSWORD=your_secure_password_here

# Backend database connection
DB_URL=jdbc:postgresql://postgres:5432/menudigital
DB_USER=menudigital
DB_PASS=your_secure_password_here

# Opcional (AWS): ARN del secreto con JSON tipo RDS { "username", "password", "host", "port", "dbname" }.
# Si está definido, la API Quarkus y el script ml-training leen usuario/clave desde Secrets Manager
# (IAM: secretsmanager:GetSecretValue). Puedes dejar DB_USER/DB_PASS vacíos si el secreto basta.
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:menudigital/rds-xxxxx
# DB_SECRET_CACHE_SECONDS=300

# =============================================================================
# AWS Configuration
# =============================================================================
# For local development, use 'local' credentials with DynamoDB Local
# For production, use real AWS credentials
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1

# =============================================================================
# DynamoDB (Analytics)
# =============================================================================
# Table name for storing analytics events
DYNAMO_TABLE=menuqr-events

# For local development with DynamoDB Local:
DYNAMO_ENDPOINT=http://dynamodb-local:8000
# For production, leave empty to use AWS DynamoDB:
# DYNAMO_ENDPOINT=

# =============================================================================
# S3 (Image Storage) - MinIO for local development
# =============================================================================
S3_BUCKET=menudigital-images

# For local development with MinIO (configured automatically in docker-compose):
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000

# For production with AWS S3, leave these empty:
# S3_ENDPOINT=
# S3_PUBLIC_URL=

# =============================================================================
# Frontend Configuration
# =============================================================================
# API URL that frontend apps will use to connect to backend
VITE_API_URL=http://localhost:8080

# Public URL of the customer-facing menu app.
# Used by the admin to generate QR codes that point to the correct menu URL.
# In production, set this to your menu domain (e.g. https://menu.yourdomain.com).
# In local dev, defaults to http://localhost:5173 if not set.
VITE_MENU_URL=http://localhost:5173

# =============================================================================
# Recommendation model (optional S3 artifact; inference still mock in app)
# En producción: bucket DEDICADO a modelos (no mezclar con imágenes del menú).
# =============================================================================
# RECOMMENDATIONS_MODEL_S3_BUCKET=menudigital-models-your-account
# Patrón de clave por tenant (literal {tenantId} obligatorio):
# Clave S3 del modelo: fija en código (recommendations/{tenantId}/model.bin)

# =============================================================================
# Application Profile
# =============================================================================
# Options: dev, test, prod
QUARKUS_PROFILE=dev

# =============================================================================
# JWT Keys (Optional - defaults exist for development)
# =============================================================================
# Path to JWT private key for signing tokens
# JWT_PRIVATE_KEY_PATH=privateKey.pem
# Path to JWT public key for verifying tokens
# JWT_PUBLIC_KEY_PATH=publicKey.pem
